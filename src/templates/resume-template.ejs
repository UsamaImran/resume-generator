<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <style><%- styles %></style>
</head>
<body>

  <!-- ===== REUSABLE HEADER (Loaded from partials) ===== -->
  <%- include('partials/header.ejs', { 
    name, 
    location, 
    phone, 
    email, 
    linkedin, 
    portfolio, 
    github, 
    targeting 
  }) %>

  <!-- ===== RESUME BODY ===== -->
  <div class="headline"><strong><%= headline %></strong></div>

  <div class="summary"><%= summary %></div>

  <h2>Technical Skills</h2>
  <% skills.forEach(function(cat) { %>
    <div class="skill-block">
      <div class="skill-category-line">
        <span class="skill-category-label"><%= cat.category %>:</span>
        <span class="skill-list">
          <%
            var skillTexts = cat.items.map(function(item) {
              if (item.highlight) {
                return '<span class="skill-item"><strong>' + item.name + '</strong></span>';
              } else {
                return '<span class="skill-item">' + item.name + '</span>';
              }
            });
          %>
          <%- skillTexts.join('') %>
        </span>
      </div>
    </div>
  <% }); %>

  <h2>Work Experience</h2>
  <% experience.forEach(function(job) { %>
    <div class="job">
      <div class="job-header">
        <span class="job-title-company"><%= job.title %> </span>
        <span class="job-title-company"> <%= job.company %></span>
      </div>
      <div class="job-header">
      <div class="job-date"><%= job.date %> </div>
      <div class="job-date"><%= job.location %></div>
      </div>
      <ul>
        <% job.bullets.forEach(function(b) { %>
          <li><%- b %></li>
        <% }); %>
      </ul>
    </div>
  <% }); %>

  <!-- ===== OPEN SOURCE ===== -->
  <% if (npmPackages && npmPackages.length > 0) { %>
    <h2>Open Source</h2>
    <ul class="open-source-list">
      <% npmPackages.forEach(function(pkg) { %>
        <%
          var parts = pkg.split(' - ');
          var name = parts[0];
          var description = parts.slice(1).join(' - ');
        %>
        <li><strong><%= name %></strong> : <%= description %></li>
      <% }); %>
    </ul>
  <% } %>

  <h2>Education</h2>
  <div class="education">
    <% education.forEach(function(edu) { %>
      <%= edu.degree %> <%= edu.fieldOfStudy ? `in ${edu.fieldOfStudy}` : '' %>,
      <%= edu.institution %>
      <% if (edu.startDate || edu.endDate) { %>
        (<%= edu.startDate %><%= edu.endDate ? ` - ${edu.endDate}` : '' %>)
      <% } %>
      <% if (edu.gpa) { %>, GPA: <%= edu.gpa %><% } %>
    <% }); %>
  </div>

</body>
</html>