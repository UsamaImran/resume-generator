<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <style><%- styles %></style>
</head>
<body>

  <!-- ===== REUSABLE HEADER (Loaded from partials) ===== -->
  <%- include('partials/header.ejs', { 
    name, 
    location, 
    phone, 
    email, 
    linkedin, 
    portfolio, 
    github, 
    targeting 
  }) %>

  <!-- ===== RESUME BODY ===== -->
  <div class="headline"><strong><%= headline %></strong></div>

  <div class="summary"><%= summary %></div>

  <h2>Technical Skills</h2>
  <% skills.forEach(function(cat) { %>
    <div class="skill-row">
      <strong><%= cat.category %>: </strong>
      <%
        var skillTexts = cat.items.map(function(item) {
          if (item.highlight) {
            return '<strong>' + item.name + '</strong>';
          } else {
            return item.name;
          }
        });
      %>
      <%- skillTexts.join(', ') %>
    </div>
  <% }); %>

  <h2>Work Experience</h2>
  <% experience.forEach(function(job) { %>
    <div class="job">
      <div class="job-main">
        <%= job.title %> <%= job.company %> — <%= job.location %>
      </div>
      <div class="job-date"><%= job.date %></div>
      <ul>
        <% job.bullets.forEach(function(b) { %>
          <li><%- b %></li>
        <% }); %>
      </ul>
    </div>
  <% }); %>

  <!-- ===== OPEN SOURCE ===== -->
  <% if (npmPackages && npmPackages.length > 0) { %>
    <h2>Open Source</h2>
    <ul class="open-source-list">
      <% npmPackages.forEach(function(pkg) { %>
        <%
          var parts = pkg.split(' - ');
          var name = parts[0];
          var description = parts.slice(1).join(' - ');
        %>
        <li><strong><%= name %></strong> : <%= description %></li>
      <% }); %>
    </ul>
  <% } %>

  <h2>Education</h2>
  <div class="education"><%= education %></div>

</body>
</html>